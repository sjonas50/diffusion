# HuggingFace API token (required for gated models like LLaMA, Mistral)
HF_TOKEN=

# Weights & Biases experiment tracking (optional — training continues without it)
WANDB_API_KEY=
WANDB_PROJECT=diffusion-lm
WANDB_RUN_NAME=

# Cache directories (optional — override HF defaults)
HF_DATASETS_CACHE=
TRANSFORMERS_CACHE=

# GPU selection for single-node multi-GPU (optional)
CUDA_VISIBLE_DEVICES=

# Suppress HF tokenizer parallelism fork warnings (set to false if needed)
TOKENIZERS_PARALLELISM=true
